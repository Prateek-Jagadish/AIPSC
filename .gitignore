# ─────────────────────────────────────────────
# UPSC Intelligence System — .gitignore
# ─────────────────────────────────────────────

# Environment
.env
*.env

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual Environment
venv/
.venv/
env/

# Storage (never commit PDFs / images)
storage/pdfs/**
storage/images/**
storage/newspapers/**
storage/temp/**
!storage/pdfs/.gitkeep
!storage/images/.gitkeep
!storage/newspapers/.gitkeep
!storage/temp/.gitkeep

# Database
*.sqlite3
*.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db

# Test
.pytest_cache/
.coverage
htmlcov/

# Alembic
# (keep migrations, but ignore __pycache__)
migrations/__pycache__/


node_modules/
frontend/node_modules/