# ─────────────────────────────────────────────────────────────────
# UPSC Intelligence System — Docker Environment
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────────────

# OpenAI (REQUIRED)
OPENAI_API_KEY=sk-your-openai-api-key-here

# PostgreSQL
POSTGRES_USER=upsc_user
POSTGRES_PASSWORD=upsc_secure_password_change_this
POSTGRES_DB=upsc_db

# App
APP_ENV=development
DEBUG=true
