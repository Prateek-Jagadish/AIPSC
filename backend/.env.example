# ─────────────────────────────────────────────
# UPSC Intelligence System — Environment Config
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
APP_NAME="UPSC Intelligence System"
APP_ENV=development           # development | production
DEBUG=true
SECRET_KEY=your-secret-key-here

# ── Database ─────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=upsc_db
POSTGRES_USER=upsc_user
POSTGRES_PASSWORD=your-db-password

# Full async URL (used by SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://upsc_user:your-db-password@localhost:5432/upsc_db

# ── OpenAI ───────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key

# Model choices
OPENAI_EMBEDDING_MODEL=text-embedding-3-large   # for chunk/image embeddings
OPENAI_CHAT_MODEL=gpt-4o                        # for tagging, captions, answers

# ── Storage ──────────────────────────────────
# Local paths (Phase 1)
STORAGE_BASE_PATH=../storage
PDF_STORAGE_PATH=../storage/pdfs
IMAGE_STORAGE_PATH=../storage/images
NEWSPAPER_STORAGE_PATH=../storage/newspapers
TEMP_PATH=../storage/temp

# AWS S3 (Phase 2 — leave blank for now)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=

# ── Redis / Celery (Background Jobs) ─────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── OCR ──────────────────────────────────────
TESSERACT_CMD=/usr/bin/tesseract   # path to tesseract binary

# ── System Behavior ──────────────────────────
# Chunking
CHUNK_SIZE=800           # tokens per chunk
CHUNK_OVERLAP=100        # overlap between chunks

# Retrieval
VECTOR_SEARCH_LIMIT=10   # max results from vector search
KEYWORD_SEARCH_LIMIT=10  # max results from full-text search
FINAL_CONTEXT_LIMIT=5    # top results passed to LLM

# Scoring
MAINS_WEIGHT=0.60        # 60% priority to Mains
PRELIMS_WEIGHT=0.40      # 40% priority to Prelims
